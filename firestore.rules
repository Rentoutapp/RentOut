rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ─────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // Safe role lookup — returns empty string if user doc doesn't exist yet.
    // This prevents rule evaluation errors during the signup window where the
    // Firebase Auth account exists but the Firestore user doc is being created.
    function getUserRole() {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : '';
    }

    // Safe status lookup — returns 'active' as default so newly registered
    // users aren't locked out before their Firestore doc is fully written.
    function getUserStatus() {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status
        : 'active';
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isLandlord() {
      return isAuthenticated() && getUserRole() == 'landlord';
    }

    // isProvider() is an alias for isLandlord() — covers all three provider
    // subtypes (landlord, agent, brokerage) since they all share role='landlord'.
    function isProvider() {
      return isAuthenticated() && getUserRole() == 'landlord';
    }

    function isTenant() {
      return isAuthenticated() && getUserRole() == 'tenant';
    }

    // Validates the providerSubtype field on write.
    // Only meaningful for role='landlord'; tenants/admins leave it blank.
    function isValidProviderSubtype(subtype) {
      return subtype in ['landlord', 'agent', 'brokerage', ''];
    }

    function isActiveUser() {
      return isAuthenticated() && getUserStatus() == 'active';
    }

    function hasUnlocked(propertyId) {
      return exists(/databases/$(database)/documents/unlocks/$(request.auth.uid + '_' + propertyId));
    }

    // ─── Users Collection ─────────────────────────────────────────────────────
    match /users/{userId} {

      // isOwner() is checked FIRST and standalone — no isActiveUser() wrapper —
      // so a user can always read their own doc. This breaks the circular dependency
      // where isAdmin()/isActiveUser() need to read the doc to determine the role/status.
      allow read: if isAuthenticated() && isOwner(userId);
      allow read: if isAuthenticated() && (isAdmin() || isActiveUser());

      // A user can create ONLY their own document immediately after signup.
      // All required fields must be present and values must be valid.
      // profilePhotoUrl is allowed to be an empty string (photo upload may fail).
      // role 'admin' cannot be self-assigned.
      //
      // Provider roles (landlord/agent/brokerage) all use role='landlord' with an
      // optional providerSubtype field. All three subtypes now collect gender and
      // nationalId (they are real people), so those fields are required for everyone.
      //
      // Agent-specific optional fields: agentLicenseNumber, yearsOfExperience.
      // Brokerage-specific optional fields: companyName, companyRegNumber,
      //   companyAddress, taxId.
      allow create: if isAuthenticated() && isOwner(userId)
        && request.resource.data.keys().hasAll([
            'uid', 'name', 'email', 'role', 'status',
            'phoneNumber', 'profilePhotoUrl', 'createdAt'
           ])
        && request.resource.data.uid == userId
        && request.resource.data.status == 'active'
        && request.resource.data.role in ['landlord', 'tenant']
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        // providerSubtype: optional field, must be a valid value if present.
        && (!('providerSubtype' in request.resource.data)
            || isValidProviderSubtype(request.resource.data.providerSubtype))
        // gender: must be a valid option if present.
        // All roles (landlord, agent, brokerage, tenant) collect gender.
        && (!('gender' in request.resource.data)
            || (request.resource.data.gender is string
                && request.resource.data.gender in [
                    '', 'Male', 'Female', 'Transgender', 'Prefer not to say'
                  ]))
        // nationalId: must be a string if present. Required validation is
        // enforced at the app layer; rules only check type for flexibility.
        && (!('nationalId' in request.resource.data)
            || request.resource.data.nationalId is string)
        // Agent-specific optional fields — strings only
        && (!('agentLicenseNumber' in request.resource.data)
            || request.resource.data.agentLicenseNumber is string)
        && (!('yearsOfExperience' in request.resource.data)
            || request.resource.data.yearsOfExperience is string)
        // Brokerage-specific optional fields — strings only
        && (!('companyName' in request.resource.data)
            || request.resource.data.companyName is string)
        && (!('companyRegNumber' in request.resource.data)
            || request.resource.data.companyRegNumber is string)
        && (!('companyAddress' in request.resource.data)
            || request.resource.data.companyAddress is string)
        && (!('taxId' in request.resource.data)
            || request.resource.data.taxId is string)
        // Brokerage company logo URL — optional, string only
        && (!('companyStreet' in request.resource.data)
            || request.resource.data.companyStreet is string)
        && (!('companyCity' in request.resource.data)
            || request.resource.data.companyCity is string)
        && (!('companyCountry' in request.resource.data)
            || request.resource.data.companyCountry is string)
        && (!('companyPhone' in request.resource.data)
            || request.resource.data.companyPhone is string)
        && (!('companyEmail' in request.resource.data)
            || request.resource.data.companyEmail is string)
        && (!('companyLogoUrl' in request.resource.data)
            || request.resource.data.companyLogoUrl is string)
        && (!('brokerageSubscriptionFeeUsd' in request.resource.data)
            || request.resource.data.brokerageSubscriptionFeeUsd is number)
        && (!('brokerageFloatBalanceUsd' in request.resource.data)
            || request.resource.data.brokerageFloatBalanceUsd is number)
        && (!('brokerageMinimumFloatUsd' in request.resource.data)
            || request.resource.data.brokerageMinimumFloatUsd is number)
        && (!('brokerageCommissionRate' in request.resource.data)
            || request.resource.data.brokerageCommissionRate is number)
        && (!('brokerageIsFrozen' in request.resource.data)
            || request.resource.data.brokerageIsFrozen is bool)
        && (!('brokerageLastTopUpAt' in request.resource.data)
            || request.resource.data.brokerageLastTopUpAt is int)
        && (!('brokerageLastDeductionAt' in request.resource.data)
            || request.resource.data.brokerageLastDeductionAt is int)
        && (!('brokerageLastTransactionId' in request.resource.data)
            || request.resource.data.brokerageLastTransactionId is string);

      // Users can update their own mutable profile fields only.
      // Immutable fields (role, status, uid, createdAt) are locked.
      // Admin can update any field including role and status.
      // gender and nationalId are mutable (user can update their profile),
      // but if changed they must remain valid typed values.
      allow update: if isAdmin()
        || (isAuthenticated() && isOwner(userId)
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['role', 'status', 'uid', 'createdAt', 'brokerageSubscriptionFeeUsd', 'brokerageFloatBalanceUsd', 'brokerageMinimumFloatUsd', 'brokerageCommissionRate', 'brokerageIsFrozen', 'brokerageLastTopUpAt', 'brokerageLastDeductionAt', 'brokerageLastTransactionId'])
          // If gender is being changed, it must still be a valid value
          && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['gender'])
              || (request.resource.data.gender is string
                  && request.resource.data.gender in [
                      '', 'Male', 'Female', 'Transgender', 'Prefer not to say'
                    ]))
          // If nationalId is being changed, it must remain a string
          && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['nationalId'])
              || request.resource.data.nationalId is string));

      // Only admin can delete user documents.
      allow delete: if isAdmin();

      // ── App Settings Subcollection ─────────────────────────────────────────
      match /app_settings/{document} {
        allow read:  if isAuthenticated() && isOwner(userId);
        allow write: if isAuthenticated() && isOwner(userId);
      }
    }

    // ─── Properties Collection ────────────────────────────────────────────────
    match /properties/{propertyId} {

      // get (single-document read): full ownership/role checks using resource.data.
      // Admin sees any property; landlord sees their own; tenant sees approved only.
      allow get: if isAuthenticated() && isActiveUser()
        && (
          isAdmin()
          || (isLandlord() && resource.data.landlordId == request.auth.uid)
          || (isTenant() && resource.data.status == 'approved')
        );

      // list (collection queries): resource.data is NOT available during query
      // evaluation in Firestore, so ownership checks cannot be applied here.
      // Security is enforced at the app level (queries always filter by landlordId
      // or status). Admin queries are unrestricted; landlords and tenants must
      // filter in their queries.
      allow list: if isAuthenticated() && isActiveUser()
        && (isAdmin() || isLandlord() || isTenant());

      // Only active providers (landlord/agent/brokerage) can create properties.
      // New listings always start as 'pending' — only admin can approve.
      // securityDeposit is optional (defaults to 0 if omitted).
      // Additional optional fields are allowed (but not required):
      // tenantRequirements, locationType, classification, availabilityDate,
      // proximityFacilities, amenities, billsInclusive, billsExclusive,
      // latitude, longitude, depositNotApplicable. Type validation is enforced
      // for optional fields to ensure data integrity.
      allow create: if isProvider() && isActiveUser()
        && request.resource.data.landlordId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.keys().hasAll([
            'title', 'city', 'location', 'price', 'rooms',
            'bathrooms', 'description', 'contactNumber',
            'propertyType', 'landlordId', 'status'
           ])
        && request.resource.data.price is number
        && request.resource.data.price > 0
        && (!('securityDeposit' in request.resource.data)
            || request.resource.data.securityDeposit is number)
        && (!('tenantRequirements' in request.resource.data)
            || request.resource.data.tenantRequirements is list)
        && (!('classification' in request.resource.data)
            || request.resource.data.classification is string)
        && (!('locationType' in request.resource.data)
            || request.resource.data.locationType is string)
        // providerSubtype: copied from the lister's profile at submit time.
        // Validates the value if present.
        && (!('providerSubtype' in request.resource.data)
            || isValidProviderSubtype(request.resource.data.providerSubtype))
        // Agent-specific optional fields — strings only
        && (!('agentName' in request.resource.data)
            || request.resource.data.agentName is string)
        && (!('agentContactNumber' in request.resource.data)
            || request.resource.data.agentContactNumber is string)
        // landlordName: for agent-listed properties, stores the landlord's full
        // name as entered by the agent. Also used as the lister's display name
        // for landlord/brokerage listings (populated from the user doc at submit).
        && (!('landlordName' in request.resource.data)
            || request.resource.data.landlordName is string)
        // Brokerage-specific optional fields — strings only
        && (!('brokerName' in request.resource.data)
            || request.resource.data.brokerName is string)
        && (!('brokerContactNumber' in request.resource.data)
            || request.resource.data.brokerContactNumber is string)
        && (!('brokerageName' in request.resource.data)
            || request.resource.data.brokerageName is string)
        && (!('brokerageLogoUrl' in request.resource.data)
            || request.resource.data.brokerageLogoUrl is string)
        && (!('brokerageAddress' in request.resource.data)
            || request.resource.data.brokerageAddress is string)
        && (!('brokerageContactNumber' in request.resource.data)
            || request.resource.data.brokerageContactNumber is string)
        && (!('brokerageEmail' in request.resource.data)
            || request.resource.data.brokerageEmail is string)
        && (!('brokerageUnlockEnabled' in request.resource.data)
            || request.resource.data.brokerageUnlockEnabled is bool)
        && (!('brokerageFreezeReason' in request.resource.data)
            || request.resource.data.brokerageFreezeReason is string);

      // Provider can update their own property details but NOT status or isVerified.
      // Admin can update anything including status (approve/reject flow).
      allow update: if isActiveUser() && (
        (isProvider() && resource.data.landlordId == request.auth.uid
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['status', 'isVerified', 'landlordId', 'brokerageUnlockEnabled', 'brokerageFreezeReason']))
        || isAdmin()
      );

      // Only admin or the owning provider can delete a property.
      allow delete: if isAdmin()
        || (isProvider() && isActiveUser() && resource.data.landlordId == request.auth.uid);

      // ── Contact Reveal Subcollection ───────────────────────────────────────
      // Contact number is only revealed after the tenant has unlocked the property.
      match /contact/{doc} {
        allow read: if isAuthenticated() && isTenant()
          && isActiveUser()
          && hasUnlocked(propertyId);
        allow write: if isAdmin();
      }
    }

    // ═══ Unlocks Collection ═══════════════════════════════════════════════════
    // Document ID format: {tenantId}_{propertyId}
    // Unlocks are created ONLY by Cloud Functions after payment is verified.
    match /unlocks/{unlockId} {
      // Single document reads (get): allow if the doc belongs to the tenant
      // OR the caller is admin. unlockId starts with tenantId so we can
      // check ownership without reading resource.data.
      allow get: if isAuthenticated() &&
        (unlockId.matches(request.auth.uid + '_.*') || isAdmin());

      // Collection queries (list): resource.data is NOT available during query
      // evaluation. We allow any authenticated user to list, trusting the app
      // to always filter by tenantId. This mirrors the transactions collection
      // pattern which already works correctly.
      allow list: if isAuthenticated();

      allow create: if false;  // Cloud Functions only via Admin SDK
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ─── Transactions Collection ──────────────────────────────────────────────
    // Created by Cloud Functions (payment webhooks) only.
    // Tenants can read their own transactions, landlords can read transactions 
    // related to their properties, and admins can read all transactions.
    // 
    // IMPORTANT: For collection queries (.where("tenantId" == uid) or 
    // .where("landlordId" == uid)), resource.data is NOT available during query 
    // evaluation. Therefore, we allow authenticated users to list/query the 
    // collection, and security relies on the app always filtering by tenantId 
    // or landlordId. Single document reads (get) verify ownership via resource.data.
    match /transactions/{transactionId} {
      // Single document read - verify ownership via resource.data
      allow get: if isAuthenticated() && (
        // Tenant can read their own transaction
        request.auth.uid == resource.data.tenantId
        // Landlord can read transactions for their properties
        || request.auth.uid == resource.data.landlordId
        // Admin can read all
        || isAdmin()
      );
      
      // Collection queries - MUST be filtered by tenantId or landlordId in app code
      // We allow authenticated users to query, trusting the app to filter properly.
      // Active user check is removed here because it creates a circular dependency
      // and prevents payment history from loading.
      allow list: if isAuthenticated();
      
      allow create: if false;  // Cloud Functions only via Admin SDK
      allow update: if false;  // Transactions are immutable
      allow delete: if isAdmin();
    }

    // ─── Brokerage Float Ledger Collection ───────────────────────────────────
    match /brokerage_float_ledger/{entryId} {
      allow get: if isAuthenticated() && (request.auth.uid == resource.data.brokerageId || isAdmin());
      allow list: if isAuthenticated();
      allow create: if false;
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ─── Brokerage Top-up Requests Collection ────────────────────────────────
    match /brokerage_topup_requests/{requestId} {
      allow get: if isAuthenticated() && (request.auth.uid == resource.data.brokerageId || isAdmin());
      allow list: if isAuthenticated();
      allow create: if false;
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ─── Notifications Collection ─────────────────────────────────────────────
    // Created by Cloud Functions (or admin) only.
    // Each notification document has a recipientId field equal to the user's UID.
    // Users can read/update(mark-read)/delete their own notifications.
    // list queries are allowed for authenticated users (app always filters by recipientId).
    match /notifications/{notificationId} {
      // Single-doc reads — owner or admin
      allow get:    if isAuthenticated()
        && (request.auth.uid == resource.data.recipientId || isAdmin());
      // Collection queries — filtered by recipientId in app code
      allow list:   if isAuthenticated();
      // Cloud Functions write via Admin SDK; admin panel can also create notifications
      allow create: if isAdmin() || isAuthenticated();
      // Users can update isRead on their own notifications; admin can update any
      allow update: if isAuthenticated()
        && (
          // Owner updating only isRead
          (request.auth.uid == resource.data.recipientId
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']))
          // Admin can update any field on any notification
          || isAdmin()
        );
      // Owner or admin can delete
      allow delete: if isAuthenticated()
        && (request.auth.uid == resource.data.recipientId || isAdmin());
    }

    // ─── Property Images Metadata (optional subcollection) ───────────────────
    // Stores ordered list of image URLs for multi-image properties.
    // Path: properties/{propertyId}/images/{imageId}
    match /properties/{propertyId}/images/{imageId} {
      allow read: if isAuthenticated() && isActiveUser();
      allow write: if isProvider() && isActiveUser()
        && get(/databases/$(database)/documents/properties/$(propertyId)).data.landlordId
           == request.auth.uid;
      allow delete: if isAdmin()
        || (isProvider() && isActiveUser()
            && get(/databases/$(database)/documents/properties/$(propertyId)).data.landlordId
               == request.auth.uid);
    }
  }
}
