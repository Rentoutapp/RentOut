rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ─── Profile Photos ───────────────────────────────────────────────────────
    // Path: profile_photos/{userId}/{fileName}
    // • Any authenticated user can read profile photos (needed for displaying
    //   landlord/tenant avatars throughout the app)
    // • Only the owning user can upload/overwrite their own photo
    // • Max file size: 5 MB
    // NOTE: contentType validation is intentionally omitted here — the gitlive
    // Firebase Storage SDK sets metadata separately from the upload, so the
    // Security Rules engine sees the contentType as null on the initial upload
    // request, causing a false 403. Content type is enforced at the app layer.
    match /profile_photos/{userId}/{fileName} {
      allow read:   if request.auth != null;
      allow write:  if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024;
      allow delete: if request.auth != null
        && request.auth.uid == userId;
    }

    // ─── Property Images ──────────────────────────────────────────────────────
    // Path: property_images/{landlordId}/{propertyId}/{fileName}
    //
    // READ: Public read is intentionally allowed (no auth check) so that:
    //   • Firebase Storage download URLs returned by getDownloadUrl() can be
    //     loaded by Coil/AsyncImage without re-authenticating on each request.
    //   • The gitlive Firebase Storage SDK issues the download URL with a
    //     Google-signed token appended (?token=...). That token IS the auth
    //     mechanism — anyone with the URL can read, but they cannot enumerate
    //     or list files without being authenticated.
    //   • Tenants on the PropertyDetailScreen hero + thumbnail strip can see
    //     all uploaded images (imageUrls list) immediately after the landlord
    //     uploads them, regardless of unlock status.
    //   • The EditPropertyImagesScreen grid reliably loads ALL existing remote
    //     images even when the Firebase Auth token is being refreshed mid-session.
    //
    // WRITE / DELETE: Restricted to the owning landlord only.
    // Max file size: 10 MB per image.
    match /property_images/{landlordId}/{propertyId}/{fileName} {
      allow read:   if true;   // token-protected download URL; see note above
      allow write:  if request.auth != null
        && request.auth.uid == landlordId
        && request.resource.size < 10 * 1024 * 1024;
      allow delete: if request.auth != null
        && request.auth.uid == landlordId;
    }

    // ─── Company Logos ────────────────────────────────────────────────────────
    // Path: company_logos/{userId}/logo.jpg
    // • Any authenticated user can read company logos (displayed in app listings)
    // • Only the owning brokerage user can upload/update their own logo
    // • Max file size: 5 MB
    match /company_logos/{userId}/{fileName} {
      allow read:   if request.auth != null;
      allow write:  if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024;
      allow delete: if request.auth != null
        && request.auth.uid == userId;
    }

    // ─── Admin Uploads ────────────────────────────────────────────────────────
    // Path: admin/{fileName}
    // Reserved for admin-uploaded assets (e.g. banner images, documents).
    // Only readable by authenticated users; only writable by admin via backend.
    match /admin/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if false; // Admin SDK / Cloud Functions only
    }

    // ─── Deny everything else ─────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
