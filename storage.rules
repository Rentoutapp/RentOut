rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ─── Profile Photos ───────────────────────────────────────────────────────
    // Path: profile_photos/{userId}/{fileName}
    // • Any authenticated user can read profile photos (needed for displaying
    //   landlord/tenant avatars throughout the app)
    // • Only the owning user can upload/overwrite their own photo
    // • Max file size: 5 MB | Allowed types: image/jpeg, image/png, image/webp
    match /profile_photos/{userId}/{fileName} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp)');
      allow delete: if request.auth != null
        && request.auth.uid == userId;
    }

    // ─── Property Images ──────────────────────────────────────────────────────
    // Path: property_images/{landlordId}/{propertyId}/{fileName}
    // • Authenticated users can read property images
    // • Only the owning landlord can upload images for their own properties
    // • Max file size: 10 MB | Allowed types: image/jpeg, image/png, image/webp
    match /property_images/{landlordId}/{propertyId}/{fileName} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == landlordId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp)');
      allow delete: if request.auth != null
        && request.auth.uid == landlordId;
    }

    // ─── Deny everything else ─────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}