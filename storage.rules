rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ─── Profile Photos ───────────────────────────────────────────────────────
    // Path: profile_photos/{userId}/{fileName}
    // • Any authenticated user can read profile photos (needed for displaying
    //   landlord/tenant avatars throughout the app)
    // • Only the owning user can upload/overwrite their own photo
    // • Max file size: 5 MB
    // NOTE: contentType validation is intentionally omitted here — the gitlive
    // Firebase Storage SDK sets metadata separately from the upload, so the
    // Security Rules engine sees the contentType as null on the initial upload
    // request, causing a false 403. Content type is enforced at the app layer.
    match /profile_photos/{userId}/{fileName} {
      allow read:   if request.auth != null;
      allow write:  if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024;
      allow delete: if request.auth != null
        && request.auth.uid == userId;
    }

    // ─── Property Images ──────────────────────────────────────────────────────
    // Path: property_images/{landlordId}/{propertyId}/{fileName}
    // • Any authenticated user can read property images (needed for the property
    //   listing cards and detail screens accessible to all active users)
    // • Only the owning landlord can upload images for their own properties
    // • Max file size: 10 MB per image
    // • Allowed types: image/jpeg, image/png, image/webp
    // NOTE: contentType check is relaxed on write (same gitlive SDK issue as above).
    //   The app layer enforces JPEG/PNG/WebP before upload.
    match /property_images/{landlordId}/{propertyId}/{fileName} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == landlordId
        && request.resource.size < 10 * 1024 * 1024;
      allow delete: if request.auth != null
        && request.auth.uid == landlordId;
    }

    // ─── Admin Uploads ────────────────────────────────────────────────────────
    // Path: admin/{fileName}
    // Reserved for admin-uploaded assets (e.g. banner images, documents).
    // Only readable by authenticated users; only writable by admin via backend.
    match /admin/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if false; // Admin SDK / Cloud Functions only
    }

    // ─── Deny everything else ─────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
