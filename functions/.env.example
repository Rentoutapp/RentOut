# Firebase Functions Environment Variables
# Copy this file to .env and fill in your actual values

# PesePay Integration Credentials
# Get these from your PesePay dashboard
PESEPAY_INTEGRATION_KEY=your_actual_pesepay_integration_key_here
PESEPAY_INTEGRATION_PASSWORD=your_actual_pesepay_integration_password_here

# For testing without real PesePay integration, use:
PESEPAY_INTEGRATION_KEY=demo_key_for_testing
PESEPAY_INTEGRATION_PASSWORD=demo_password_for_testing

# Other environment variables as needed
# FIREBASE_PROJECT_ID=your-project-id
# etc.
